      "parameters": {
        "language": "pythonNative",
        "pythonCode": "texto = _items[0][\"json\"][\"message\"][\"text\"]\npartes = texto.split()\ntipo = partes[0].lower()\nchat_id = _items[0][\"json\"][\"message\"][\"chat\"][\"id\"]\n\nif tipo == \"saldo\":\n    return [{\"json\": {\"tipo\": \"saldo\", \"chat_id\": chat_id}}]\n\nif tipo == \"/start\":\n    return [{\"json\": {\"tipo\": \"start\", \"chat_id\": chat_id}}]\n\nif len(partes) < 2:\n    return [{\"json\": {\"tipo\": \"erro\", \"chat_id\": chat_id}}]\n\nvalor_str = partes[1].replace(\",\", \".\")\nvalor = float(valor_str)\nvalor_fmt = \"{:.2f}\".format(valor)\ndescricao = \" \".join(partes[3:])\n\nreturn [{\"json\": {\"tipo\": tipo, \"valor\": valor_fmt, \"descricao\": descricao, \"chat_id\": chat_id}}]"
      },
