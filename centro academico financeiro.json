    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "entradas = 0\nsaidas = 0\n\nfor item in _items:\n    if not item or not item.get(\"json\"):\n        continue\n        \n    tipo = item[\"json\"].get(\"TIPO\", \"\")\n    valor_raw = item[\"json\"].get(\"VALOR\", 0)\n    \n    if not tipo or not valor_raw:\n        continue\n        \n    valor = float(str(valor_raw).replace(\",\", \".\"))\n    \n    if tipo == \"entrada\":\n        entradas += valor\n    elif tipo == \"saida\":\n        saidas += valor\n\nsaldo = entradas - saidas\n\nentradas_fmt = \"{:.2f}\".format(entradas)\nsaidas_fmt = \"{:.2f}\".format(saidas)\nsaldo_fmt = \"{:.2f}\".format(saldo)\n\nreturn [{\"json\": {\"entradas\": entradas_fmt, \"saidas\": saidas_fmt, \"saldo\": saldo_fmt}}]"
      },
